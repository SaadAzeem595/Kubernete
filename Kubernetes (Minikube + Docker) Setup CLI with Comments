📄 Kubernetes (Minikube + Docker) Working CLI with Comments

# ==========================================
# 1. Start Minikube with Docker Driver
# ==========================================
minikube start --driver=docker

# NOTE:
# - Uses Docker instead of Hyper-V (recommended for Windows)
# - If gcr.io fails → fallback image from docker.io is used (OK)


# ==========================================
# 2. Check Minikube Status
# ==========================================
minikube status

# Expected Output:
# host: Running
# kubelet: Running
# apiserver: Running
# kubeconfig: Configured


# ==========================================
# 3. Verify Kubernetes Cluster
# ==========================================
kubectl get nodes

# Output:
# minikube   Ready   control-plane


# ==========================================
# 4. Check Docker Container (Minikube VM)
# ==========================================
docker ps

# Shows minikube container running (kicbase image)


# ==========================================
# 5. Open Kubernetes Dashboard (Optional)
# ==========================================
minikube dashboard

# Opens browser UI for cluster management
# NOTE:
# Press Ctrl+C to stop dashboard proxy


# ==========================================
# 6. Create Deployment (Nginx App)
# ==========================================
kubectl create deployment my-nginx --image=nginx:latest

# Deployment automatically creates a Pod


# ==========================================
# 7. Check Deployment Status
# ==========================================
kubectl get deployments

# READY column should become 1/1 after some time


# ==========================================
# 8. Check Pods
# ==========================================
kubectl get pods

# Pod status should be:
# Running


# ==========================================
# 9. Expose Deployment (Make App Accessible)
# ==========================================
kubectl expose deployment my-nginx --type=NodePort --port=80

# NodePort exposes service outside cluster


# ==========================================
# 10. Check Services
# ==========================================
kubectl get services

# Example Output:
# my-nginx   NodePort   80:32255/TCP


# ==========================================
# 11. Access Application
# ==========================================
minikube service my-nginx

# Opens browser with URL
# NOTE:
# Keep terminal open (required for tunnel on Windows)


# ==========================================
# 12. Delete Resources (Cleanup)
# ==========================================

# Delete service
kubectl delete service my-nginx

# Delete deployment
kubectl delete deployment my-nginx


# ==========================================
# 13. Stop or Delete Minikube (Optional)
# ==========================================

# Stop cluster
minikube stop

# Delete cluster completely
minikube delete

