# 👉 Removes incorrect service

# Apply correct service config
kubectl apply -f service-node-app.yml
# 👉 Creates LoadBalancer service

# Recheck services
kubectl get services
# 👉 EXTERNAL-IP may be <pending> in Minikube (normal)

# Delete broken deployments (clean restart)
kubectl delete deployment node-app
kubectl delete deployment my-node-app
# 👉 Removes old faulty pods and configs

# Reapply fresh deployment
kubectl apply -f deployment-node-app.yml
# 👉 Starts clean deployment with corrected image

# Check pods again
kubectl get pods
# 👉 Ensure no ImagePullBackOff now






