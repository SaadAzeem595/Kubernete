🚀 Kubernetes Scaling + Service Access (Documented CLI)
# ----------------------------------------------------------
# STEP 1: Start Minikube Cluster (Docker Driver)
# ----------------------------------------------------------
minikube start --driver=docker
# Starts Kubernetes cluster using Docker instead of Hyper-V/VM

minikube status
# Verify cluster is running (host, kubelet, apiserver should be Running)


# ----------------------------------------------------------
# STEP 2: Check Existing Pods
# ----------------------------------------------------------
kubectl get pods
# Initially only 1 pod is running (default replica = 1)


# ----------------------------------------------------------
# STEP 3: Scale Application (Horizontal Scaling)
# ----------------------------------------------------------
kubectl scale deployment node-app --replicas=4
# Increase number of pods (replicas) from 1 → 4

kubectl get pods
# Verify 4 pods are created and running


# ----------------------------------------------------------
# STEP 4: Access Application via Service
# ----------------------------------------------------------
minikube service node-app
# Opens service in browser via NodePort + tunnel
# IMPORTANT: Terminal must stay open (Windows Docker driver requirement)


# ----------------------------------------------------------
# STEP 5: Observe Self-Healing Behavior
# ----------------------------------------------------------
kubectl get pods
# You may see RESTARTS increasing → Kubernetes auto-restarts crashed containers


# ----------------------------------------------------------
# STEP 6: Scale Down Application
# ----------------------------------------------------------
kubectl scale deployment node-app --replicas=2
# Reduce replicas from 4 → 2

kubectl get pods
# Some pods go into "Terminating" state → expected behavior


# ----------------------------------------------------------
# STEP 7: Final Pod State Check
# ----------------------------------------------------------
kubectl get pods
# Only 2 pods should remain in Running state


# ----------------------------------------------------------
# STEP 8: Optional - Monitor in Real Time
# ----------------------------------------------------------
kubectl get pods -w
# Watch pods live (creation, termination, restart events)



