Kubernetes (Minikube + Docker) Setup CLI with Comments

# ================================
# 1. Install Minikube (already done)
# ================================
choco install minikube


# ================================
# 2. Start Docker Desktop FIRST
# ================================
# IMPORTANT:
# - Open Docker Desktop manually
# - Wait until it says "Docker is running"

docker ps
# If error → Docker is NOT running


# ================================
# 3. Clean previous broken Minikube
# ================================
minikube delete --all --purge

# Also manually delete leftover folder (VERY IMPORTANT)
# Path:
# C:\Users\saada\.minikube


# ================================
# 4. Start Minikube using Docker driver
# ================================
minikube start --driver=docker

# NOTE:
# If error like "gcr.io not reachable"
# → It is INTERNET / DNS issue


# ================================
# 5. Fix DNS issue (IMPORTANT for your case)
# ================================
# Run this if "gcr.io: no such host" error appears

ipconfig /flushdns

# OR set DNS manually (recommended)
# Use Google DNS:
# 8.8.8.8
# 8.8.4.4


# ================================
# 6. Verify Minikube is running
# ================================
minikube status

# Expected output:
# host: Running
# kubelet: Running
# apiserver: Running
# kubeconfig: Configured


# ================================
# 7. Verify Kubernetes connection
# ================================
kubectl get nodes

# Expected:
# minikube   Ready


# ================================
# 8. Create Deployment (Node App)
# ================================
kubectl create deployment node-app --image=philippaul/node-demo-app:01

# This creates a pod running your container


# ================================
# 9. Check Pods
# ================================
kubectl get pods


# ================================
# 10. Expose Deployment (Make it accessible)
# ================================
kubectl expose deployment node-app --type=NodePort --port=3000


# ================================
# 11. Access your app
# ================================
minikube service node-app

# This will open browser automatically


# ================================
# 12. Debugging Commands
# ================================

# Check logs
kubectl logs <pod-name>

# Describe pod (very useful)
kubectl describe pod <pod-name>

# Check services
kubectl get services

# Delete deployment
kubectl delete deployment node-app

# Delete service
kubectl delete service node-app

